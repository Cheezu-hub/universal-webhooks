# -------------------------------------------------------
# Universal Webhook Adapter v2 — Environment Configuration
# -------------------------------------------------------

# --- Anthropic (required for AI mapping) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Webhook Signature Secrets ---
# Leave blank to skip verification for that provider.
STRIPE_WEBHOOK_SECRET=whsec_...
GITHUB_WEBHOOK_SECRET=ghsec_...

# --- Rate Limiting ---
# Format: "<count>/<period>"  e.g. 100/minute, 500/hour
RATE_LIMIT=100/minute

# --- Background Queue & Retry ---
MAX_QUEUE_SIZE=1000          # Max in-memory jobs before 503 is returned
MAX_RETRY_ATTEMPTS=3         # Queue-level retries per webhook
RETRY_DELAY_BASE=2.0         # Exponential backoff base in seconds (2^attempt)

# --- AI Mapper ---
AI_TIMEOUT_SECONDS=30.0      # Per-request HTTP timeout to Claude API
AI_MAX_RETRIES=3             # API-level retries (rate-limit / 5xx / timeout)

# --- Logging ---
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
